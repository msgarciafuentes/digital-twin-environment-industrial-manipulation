<mujoco model="fusion_preview_all_parts">

  <!--
    Place this XML in the same folder as:
      Switch_tile.stl
      LED_tile.stl
      Connector_tile.stl
      300mm .stl
      450mm.stl
      600mm.stl

    Notes:
    - scale="0.001 0.001 0.001" assumes Fusion exported in millimeters.
    - If the objects look too small, change scale to 0.01 or 1 depending on your export units.
    - You can comment out any <mesh> in <asset> and/or any <body> in <worldbody>.
  -->

  <compiler angle="degree" coordinate="local" meshdir="."/>
  <option gravity="0 0 -9.81" timestep="0.002"/>

  <visual>
    <headlight diffuse="0.8 0.8 0.8" ambient="0.3 0.3 0.3" specular="0.2 0.2 0.2"/>
    <rgba haze="0.15 0.25 0.35 1"/>
  </visual>

  <asset>
    <!-- ========================= -->
    <!--           MESHES          -->
    <!-- ========================= -->

    <!-- Comment out any mesh you do not want to load -->

    <mesh name="switch_tile_mesh"     file="..\meshes\Switch_tile.stl"    scale="0.005 0.005 0.005"/>
    <mesh name="led_tile_mesh"        file="..\meshes\LED_tile.stl"       scale="0.005 0.005 0.005"/>
    <mesh name="connector_tile_mesh"  file="..\meshes\Connector_tile.stl" scale="0.005 0.005 0.005"/>
    <mesh name="normal_tile_mesh"  file="..\meshes\tile.stl" scale="0.005 0.005 0.005"/>

    <!-- Note: this filename includes a space before .stl -->
    <mesh name="part_300mm_mesh"      file="..\meshes\300mm.stl"         scale="0.005 0.005 0.005"/>
    <mesh name="part_450mm_mesh"      file="..\meshes\450mm.stl"          scale="0.005 0.005 0.005"/>
    <mesh name="part_600mm_mesh"      file="..\meshes\600mm.stl"          scale="0.005 0.005 0.005"/>
  </asset>

  <default>
    <geom type="mesh"
          contype="0"
          conaffinity="0"
          rgba="0.72 0.72 0.72 1"/>

    <default class="switch_visual">
      <geom type="box" contype="1" conaffinity="1" friction="1 0.1 0.1"/>
    </default>
  </default>

  <worldbody>
    <!-- ========================= -->
    <!--      LIGHTS / FLOOR       -->
    <!-- ========================= -->

    <light name="top_light_1" pos="0 0 3"/>
    <light name="top_light_2" pos="2 0 3"/>
    <light name="top_light_3" pos="-2 0 3"/>

    <geom name="floor" type="plane" size="5 5 0.1" rgba="0 0 0 1"/>

    <!-- ========================= -->
    <!--         CAMERAS           -->
    <!-- ========================= -->

    <!-- Wide camera for all parts -->
    <camera name="overview" pos="0 2.8 1.6" xyaxes="1 0 0 0 0.5 1"/>

    <!-- Alternative side camera -->
    <camera name="side" pos="3 0 1.2" xyaxes="0 1 0 -0.3 0 1"/>

    <!-- ========================= -->
    <!--        MESH BODIES        -->
    <!-- ========================= -->

    <!--
      Each body is separated and placed side by side.
      You can comment out any whole body block whenever you want.
    -->

   <!-- Ground first tile series -->
    <body name="switch_tile_body" pos="-1.50 0 0.05">
      <geom name="switch_tile_geom" mesh="switch_tile_mesh" rgba="0.75 0.75 0.75 1"/>
    </body>
    
    <body name="led_tile_body" pos="-0.75 0 0.05">
      <geom name="led_tile_geom" mesh="switch_tile_mesh" rgba="0.70 0.70 0.78 1"/>
    </body>
    
    <body name="connector_tile_body" pos="0.00 0 0.05">
      <geom name="connector_tile_geom" mesh="switch_tile_mesh" rgba="0.78 0.72 0.70 1"/>
    </body>

    <body name="connector_tile_body2" pos="0.75 0 0.05">
      <geom name="connector_tile_geom2" mesh="switch_tile_mesh" rgba="0.78 0.72 0.70 1"/>
    </body>

  <!-- Ground second tile series -->
    <body name="connector_tile_body3" pos="-1.50 -0.75 0.05">
      <geom name="connector_tile_geom3" mesh="switch_tile_mesh" rgba="0.78 0.72 0.70 1"/>
    </body>

    <body name="connector_tile_body4" pos="-0.75 -0.75 0.05">
      <geom name="connector_tile_geom4" mesh="switch_tile_mesh" rgba="0.78 0.72 0.70 1"/>
    </body>

    <body name="connector_tile_body5" pos="0.00 -0.75 0.05">
      <geom name="connector_tile_geom5" mesh="switch_tile_mesh" rgba="0.78 0.72 0.70 1"/>
    </body>

    <body name="connector_tile_body6" pos="0.75 -0.75 0.05">
      <geom name="connector_tile_geom6" mesh="switch_tile_mesh" rgba="0.78 0.72 0.70 1"/>
    </body>

  <!-- Upper first tile series -->
    <body name="switch_tile_body2" pos="-1.50 0.35 0.43" euler="90 0 0">
      <geom name="switch_tile_geom2" mesh="switch_tile_mesh" rgba="0.75 0.75 0.75 1"/>
    </body>

    <body name="switch_tile_body3" pos="-0.75 0.35 0.43" euler="90 0 0">
      <geom name="switch_tile_geom3" mesh="switch_tile_mesh" rgba="0.75 0.75 0.75 1"/>
    </body>

    <body name="switch_tile_body4" pos="0 0.35 0.43" euler="90 0 0">
      <geom name="switch_tile_geom4" mesh="switch_tile_mesh" rgba="0.75 0.75 0.75 1"/>

      <!-- Simple toggle switch mounted on this panel -->
      <body name="panel_switch_mount" pos="-1 0.02 0.00">
        <geom name="panel_switch_base" class="switch_visual" size="0.035 0.02 0.008" pos="0 0 0" rgba="0.15 0.15 0.15 1"/>

        <body name="panel_switch_toggle" pos="0 0 0.008">
          <joint name="panel_switch_hinge" type="hinge" axis="1 0 0" range="-0.6 0.6" damping="0.4" frictionloss="0.05"/>
          <geom name="panel_switch_lever" class="switch_visual" type="box" size="0.008 0.012 0.03" pos="0 0 0.03" rgba="0.85 0.15 0.15 1"/>
        </body>
      </body>
    </body>

    <body name="switch_tile_body5" pos="0.75 0.35 0.43" euler="90 0 0">
      <geom name="switch_tile_geom5" mesh="switch_tile_mesh" rgba="0.75 0.75 0.75 1"/>
    </body>

  <!-- Upper second tile series -->
    <body name="switch_tile_body6" pos="-1.50 0.35 1.18" euler="90 0 0">
      <geom name="switch_tile_geom6" mesh="switch_tile_mesh" rgba="0.75 0.75 0.75 1"/>
    </body>

    <body name="switch_tile_body7" pos="-0.75 0.35 1.18" euler="90 0 0">
      <geom name="switch_tile_geom7" mesh="switch_tile_mesh" rgba="0.75 0.75 0.75 1"/>
    </body>

    <body name="switch_tile_body8" pos="0 0.35 1.18" euler="90 0 0">
      <geom name="switch_tile_geom8" mesh="switch_tile_mesh" rgba="0.75 0.75 0.75 1"/>
    </body>

    <body name="switch_tile_body9" pos="0.75 0.35 1.18" euler="90 0 0">
      <geom name="switch_tile_geom9" mesh="switch_tile_mesh" rgba="0.75 0.75 0.75 1"/>
    </body>

  <!-- Upper third tile series -->
    <body name="switch_tile_body10" pos="-1.50 0.35 1.93" euler="90 0 0">
      <geom name="switch_tile_geom10" mesh="switch_tile_mesh" rgba="0.75 0.75 0.75 1"/>
    </body>

    <body name="switch_tile_body11" pos="-0.75 0.35 1.93" euler="90 0 0">
      <geom name="switch_tile_geom11" mesh="switch_tile_mesh" rgba="0.75 0.75 0.75 1"/>
    </body>

    <body name="switch_tile_body12" pos="0 0.35 1.93" euler="90 0 0">
      <geom name="switch_tile_geom12" mesh="switch_tile_mesh" rgba="0.75 0.75 0.75 1"/>
    </body>

    <body name="switch_tile_body13" pos="0.75 0.35 1.93" euler="90 0 0">
      <geom name="switch_tile_geom13" mesh="switch_tile_mesh" rgba="0.75 0.75 0.75 1"/>
    </body>
  </worldbody>

  <actuator>
    <position name="panel_switch_act" joint="panel_switch_hinge" kp="15" ctrlrange="-0.6 0.6"/>
  </actuator>

  <sensor>
    <jointpos name="panel_switch_pos" joint="panel_switch_hinge"/>
    <jointvel name="panel_switch_vel" joint="panel_switch_hinge"/>
  </sensor>
</mujoco>